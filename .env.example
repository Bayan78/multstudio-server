# --- LLM (история). Без ключа работает простой встроенный фолбэк. ---
# Groq (быстро и бесплатно): https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# --- Картинки: Pollinations (бесплатно, без ключа). ---
# Токен нужен только для повышенных лимитов (по желанию): https://pollinations.ai
POLLINATIONS_TOKEN=
POLLINATIONS_MODEL=flux

# --- Озвучка ---
# ElevenLabs (живой голос, нужен ключ с правом Text to Speech): https://elevenlabs.io
ELEVENLABS_API_KEY=
# Без ключа ElevenLabs используется edge-tts, затем gTTS (робот).

# Фоновая музыка: положи роялти-фри mp3 в assets/music/
